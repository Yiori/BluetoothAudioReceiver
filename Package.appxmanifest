<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 rescap">

  <Identity
    Name="BluetoothAudioReceiver"
    Publisher="CN=BluetoothAudioReceiver"
    Version="1.0.0.0" />

  <Properties>
    <DisplayName>Bluetooth Audio Receiver</DisplayName>
    <PublisherDisplayName>BluetoothAudioReceiver</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="pt-BR"/>
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="BluetoothAudioReceiver.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Bluetooth Audio Receiver"
        Description="Permite que o Windows funcione como receptor de áudio Bluetooth"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- runFullTrust: necessario para apps desktop (Win32) em MSIX -->
    <rescap:Capability Name="runFullTrust" />

    <!-- backgroundMediaPlayback: necessario para conexao A2DP Sink no Windows -->
    <uap3:Capability Name="backgroundMediaPlayback" />

    <!-- bluetooth (DeviceCapability): acesso ao hardware Bluetooth -->
    <DeviceCapability Name="bluetooth" />
  </Capabilities>

</Package>
